@{
    ViewData["Title"] = "Iniciar Sesión";
    Layout = null; // CRÍTICO: Esto elimina las barras de Dashboard y Canchas de esta página
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Reserva.NET</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;600;800&display=swap" rel="stylesheet">

    <style>
        body {
            font-family: 'Plus Jakarta Sans', sans-serif;
            /* Imagen de fondo deportiva con superposición oscura para resaltar el formulario */
            background: linear-gradient(rgba(15, 23, 42, 0.8), rgba(15, 23, 42, 0.8)), url('https://images.unsplash.com/photo-1574629810360-7efbbe195018?q=80&w=1600&auto=format&fit=crop');
            background-size: cover;
            background-position: center;
            background-attachment: fixed;
            height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0;
            overflow: hidden;
        }

        .glass-card {
            background: rgba(255, 255, 255, 0.95);
            backdrop-filter: blur(10px);
            border-radius: 32px;
            padding: 2.5rem;
            width: 100%;
            max-width: 450px;
            box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.5);
            border: 1px solid rgba(255, 255, 255, 0.3);
            animation: fadeIn 0.8s ease-out;
        }

        @@keyframes fadeIn {
            from {
                opacity: 0;
                transform: translateY(20px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .brand-badge {
            width: 60px;
            height: 60px;
            background: #27F5CC; /* Color de tu marca */
            border-radius: 16px;
            display: grid;
            place-items: center;
            margin: 0 auto 1rem;
            color: #0f172a;
            box-shadow: 0 10px 20px rgba(39, 245, 204, 0.3);
        }

        .elec-title {
            font-weight: 800;
            color: #0f172a;
            letter-spacing: -1px;
        }

        .form-label {
            color: #475569;
            font-size: 0.85rem;
            margin-bottom: 0.5rem;
        }

        .elec-form-control {
            background: #f8fafc;
            border: 2px solid #e2e8f0;
            padding: 12px 16px;
            border-radius: 14px;
            transition: all 0.3s ease;
        }

            .elec-form-control:focus {
                border-color: #27F5CC;
                box-shadow: 0 0 0 4px rgba(39, 245, 204, 0.1);
                background: white;
            }

        .elec-btn-primary {
            background: #0f172a;
            color: white;
            border: none;
            padding: 14px;
            border-radius: 14px;
            transition: all 0.3s ease;
        }

            .elec-btn-primary:hover {
                background: #27F5CC;
                color: #0f172a;
                transform: translateY(-2px);
                box-shadow: 0 12px 20px rgba(39, 245, 204, 0.3);
            }

        .text-info-custom {
            color: #27F5CC;
            text-decoration: none;
            font-weight: 700;
        }

            .text-info-custom:hover {
                color: #0f172a;
                text-decoration: underline;
            }
    </style>
</head>
<body>

    <div class="glass-card">
        <div class="text-center mb-4">
            <div class="brand-badge">
                <i class="bi bi-lightning-charge-fill fs-3"></i>
            </div>
            <h2 class="elec-title mb-1">Reserva<span style="color: #27F5CC;">.NET</span></h2>
            <p class="text-muted small">Tu próxima victoria empieza aquí</p>
        </div>

        <form asp-action="Login" asp-controller="Account" method="post">
            <div class="mb-3">
                <label class="form-label fw-bold">
                    <i class="bi bi-envelope me-2"></i>Correo Electrónico
                </label>
                <input type="text" class="form-control elec-form-control"
                       name="username" required placeholder="nombre@correo.com">
            </div>

            <div class="mb-4">
                <label class="form-label fw-bold">
                    <i class="bi bi-key me-2"></i>Contraseña
                </label>
                <input type="password" class="form-control elec-form-control"
                       name="password" required placeholder="••••••••">
            </div>

            <button type="submit" class="btn elec-btn-primary w-100 fw-bold mb-3 shadow-sm">
                <i class="bi bi-box-arrow-in-right me-2"></i>INGRESAR AL SISTEMA
            </button>

            @if (ViewBag.ErrorMessage != null)
            {
                <div class="alert alert-danger text-center border-0 small py-2 rounded-3">
                    <i class="bi bi-exclamation-octagon-fill me-2"></i>@ViewBag.ErrorMessage
                </div>
            }
        </form>

        <div class="text-center mt-4 pt-3 border-top">
            <p class="text-muted small mb-1">¿Aún no tienes cuenta?</p>
            <a asp-action="Register" asp-controller="Account" class="text-info-custom small">
                Regístrate aquí <i class="bi bi-arrow-right ms-1"></i>
            </a>
        </div>
    </div>

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>