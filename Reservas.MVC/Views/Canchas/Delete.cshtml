@model Reserva.Modelos.Canchas

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-5 text-center">
            <div class="card border-0 shadow-lg rounded-4 p-4">
                <div class="display-1 text-danger mb-3">
                    <i class="bi bi-exclamation-triangle"></i>
                </div>
                <h2 class="fw-bold">¿Eliminar cancha?</h2>
                <p class="text-muted">Estás a punto de borrar <strong>@Model.nombre_cancha</strong>. Esta acción no se puede deshacer.</p>

                <form asp-action="DeleteConfirmed" method="post" asp-route-id="@Model.Id">
                    <div class="d-grid gap-2 mt-4">
                        <button type="submit" class="btn btn-danger btn-modern py-3">
                            <i class="bi bi-trash me-2"></i>Confirmar Eliminación
                        </button>
                        <a asp-action="Admin" class="btn btn-link text-muted text-decoration-none">
                            Cancelar y volver
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
