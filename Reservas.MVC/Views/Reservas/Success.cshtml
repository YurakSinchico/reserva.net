@model Reserva.Modelos.Reservas

@{
    ViewData["Title"] = "¡Reserva Confirmada!";
    var nombreUsuario = User.Identity?.Name ?? "Cliente";
}

<div class="success-bg-wrapper">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-md-6 col-lg-5">

                @* AÑADIDA LA CLASE DE ANIMACIÓN AQUÍ *@
                <div class="card success-card shadow-lg text-center animate-success-card">

                    <div class="card-header success-header border-0">
                        <div class="display-1 mb-2"><i class="bi bi-check-circle-fill"></i></div>
                        <h2 class="fw-bold mb-0">¡Reserva Lista!</h2>
                    </div>

                    <div class="card-body p-4 p-md-5">
                        <p class="fs-4">¡Excelente elección, <strong>@nombreUsuario</strong>!</p>

                        <p class="text-muted mb-4">
                            Tu reserva para el día <strong>@TempData["FechaExito"]</strong>
                            ha sido creada con éxito. ¡Prepárate para el juego!
                        </p>

                        <div class="alert info-box-minimal p-3 mb-4">
                            <div class="d-flex align-items-center justify-content-center mb-2">
                                <i class="bi bi-info-circle-fill fs-4 me-2"></i>
                                <span class="fw-bold">Para tu comodidad:</span>
                            </div>
                            <p class="small mb-0">
                                Te sugerimos llegar <span class="badge rounded-pill bg-primary">10 minutos antes</span>
                                de tu turno para empezar a tiempo.
                            </p>
                        </div>

                        <div class="d-grid gap-2">
                            <a asp-action="Index" class="btn btn-success-primary btn-lg rounded-pill text-white shadow-sm">
                                Ver todas mis reservas
                            </a>
                            <a asp-controller="Home" asp-action="Index" class="btn btn-link text-muted text-decoration-none small fw-bold">
                                Volver al inicio
                            </a>
                        </div>
                    </div>

                    <div class="card-footer bg-light text-muted py-3 small border-0">
                        © @DateTime.Now.Year Reserva.NET - Gestión Deportiva
                    </div>
                </div>

            </div>
        </div>
    </div>
</div>