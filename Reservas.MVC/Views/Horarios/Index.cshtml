@model IEnumerable<Reserva.Modelos.Horarios>
<link rel="stylesheet" href="~/css/admin-vivid.css" />

<div class="cuerpo-gestion p-5">
    <div class="container">
        <div class="d-flex justify-content-between align-items-end mb-5">
            <div>
                <h1 class="titulo-vivid mb-0">
                    Gestión de <span class="text-neon">Horarios</span>
                </h1>
                <p class="opacity-50 fs-5 fw-bold">ADMINISTRACIÓN DE BLOQUES DE TIEMPO</p>
            </div>
            <a asp-action="Create" class="btn p-3 shadow-lg fw-900"
               style="background: #27F5CC; color: #0f172a; border-radius: 15px;">
                <i class="bi bi-plus-circle-fill me-2"></i> NUEVO HORARIO
            </a>
        </div>

        <div class="panel-glass">
            <div class="table-responsive">
                <table class="table table-borderless align-middle text-white">
                    <thead>
                        <tr class="text-neon border-bottom border-secondary">
                            <th class="py-3 fw-900">REF</th>
                            <th class="py-3 text-center fw-900">HORA APERTURA</th>
                            <th class="py-3 text-center fw-900">HORA CIERRE</th>
                            <th class="py-3 text-end fw-900">GESTIÓN</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr class="border-bottom border-white border-opacity-10">
                                <td class="fw-bold opacity-75">ID-@item.Id</td>
                                <td class="text-center">
                                    <div class="pill-tiempo">
                                        <i class="bi bi-clock-fill text-neon"></i>
                                        @item.hora_inicio.ToString(@"HH\:mm")
                                    </div>
                                </td>
                                <td class="text-center">
                                    <div class="pill-tiempo" style="border-color: #27F5CC;">
                                        <i class="bi bi-door-closed-fill text-neon"></i>
                                        @item.hora_fin.ToString(@"HH\:mm")
                                    </div>
                                </td>
                                <td class="text-end">
                                    <form asp-action="Delete" asp-route-id="@item.Id" method="post" class="d-inline">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn btn-outline-danger border-2 fw-bold px-4"
                                                onclick="return confirm('¿Eliminar horario?')">
                                            ELIMINAR
                                        </button>
                                    </form>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>