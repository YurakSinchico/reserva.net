<div class="container">
    <div class="d-flex justify-content-between align-items-center my-4">
        <h2 class="fw-bold">Gestión de Inventario</h2>
        <a asp-action="Create" class="btn btn-dark btn-modern">
            <i class="bi bi-plus-lg me-2"></i>Nueva Cancha
        </a>
    </div>

    <div class="bg-white p-3 rounded-4 shadow-sm">
        <table class="table align-middle">
            <thead class="text-muted small text-uppercase">
                <tr>
                    <th>Cancha</th>
                    <th>Tipo</th>
                    <th>Estado</th>
                    <th class="text-end">Acciones</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>
                            <div class="fw-bold">@item.nombre_cancha</div>
                            <div class="small text-muted">ID: @item.Id</div>
                        </td>
                        <td>
                            <span class="badge border text-dark fw-normal">@item.Tipo_Canchas?.nombre_tip_cancha</span>
                        </td>
                        <td>
                            <div class="form-check form-switch">
                                <input class="form-check-input" type="checkbox" @(item.estado_cancha ? "checked" : "") disabled>
                            </div>
                        </td>
                        <td class="text-end">
                            <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-light btn-sm rounded-3"><i class="bi bi-pencil"></i></a>
                            <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-light btn-sm rounded-3 text-danger"><i class="bi bi-trash"></i></a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>