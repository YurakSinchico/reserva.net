@model IEnumerable<Reserva.Modelos.Horarios>

@{
    ViewData["Title"] = "Gestión de Horarios";
}

<div class="container mt-4 mb-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-800 text-dark mb-0">Gestión de <span style="color: #27F5CC;">Horarios</span></h2>
            <p class="text-muted small">Administra los bloques de tiempo disponibles para las canchas</p>
        </div>
        <a asp-action="Create" class="btn btn-dark px-4 py-2 shadow-sm d-flex align-items-center" style="border-radius: 12px; font-weight: 600;">
            <i class="bi bi-plus-circle-fill me-2"></i> Nuevo Horario
        </a>
    </div>

    <div class="card border-0 shadow-lg" style="border-radius: 20px; overflow: hidden;">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead style="background-color: #f8fafc;">
                    <tr>
                        <th class="py-4 ps-4 text-muted small text-uppercase fw-bold" style="letter-spacing: 1px;">ID</th>
                        <th class="py-4 text-muted small text-uppercase fw-bold" style="letter-spacing: 1px;">Hora Inicio</th>
                        <th class="py-4 text-muted small text-uppercase fw-bold" style="letter-spacing: 1px;">Hora Fin</th>
                        <th class="py-4 text-end pe-4 text-muted small text-uppercase fw-bold" style="letter-spacing: 1px;">Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="ps-4">
                                <span class="badge bg-light text-dark rounded-pill px-3 py-2">#@item.Id</span>
                            </td>
                            <td>
                                <div class="d-flex align-items-center">
                                    <i class="bi bi-clock-fill me-2" style="color: #27F5CC;"></i>
                                    <span class="fw-bold text-dark fs-5">@item.hora_inicio.ToString(@"hh\:mm")</span>
                                </div>
                            </td>
                            <td>
                                <span class="text-muted fw-semibold">@item.hora_fin.ToString(@"hh\:mm")</span>
                            </td>
                            <td class="text-end pe-4">
                                <a asp-action="Delete" asp-route-id="@item.Id"
                                   class="btn btn-outline-danger btn-sm px-3 py-2 d-inline-flex align-items-center shadow-sm"
                                   style="border-radius: 10px; transition: all 0.3s ease; border-width: 2px;"
                                   onclick="return confirm('¿Estás seguro de que deseas eliminar este horario?')">
                                    <i class="bi bi-trash3-fill me-2"></i> Eliminar
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<style>
    /* Efecto de elevación en la fila al pasar el mouse */
    .table-hover tbody tr:hover {
        background-color: rgba(39, 245, 204, 0.03);
        transition: background-color 0.2s ease;
    }

    .fw-800 {
        font-weight: 800;
    }
</style>