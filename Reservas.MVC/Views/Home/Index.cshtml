@{
    ViewData["Title"] = "Tu Portal Deportivo";
    var nombreUsuario = User.Identity?.Name ?? "Deportista";
}

<style>
    /* Fondo general suave para resaltar las tarjetas */
    .dashboard-container {
        background-color: #f8fafc;
        border-radius: 24px;
        padding: 40px;
        box-shadow: inset 0 2px 10px rgba(0,0,0,0.02);
    }

    /* Tarjeta Deportiva Principal (Inmersiva) */
    .sport-card-immersive {
        position: relative;
        border-radius: 24px;
        height: 350px; /* Altura generosa para la imagen de fondo */
        overflow: hidden;
        border: none;
        transition: all 0.5s cubic-bezier(0.4, 0, 0.2, 1); /* Transición suave */
        cursor: pointer;
        box-shadow: 0 10px 30px rgba(0,0,0,0.1);
        display: block; /* Toda la tarjeta es un enlace */
        text-decoration: none !important;
    }

        /* Efecto Hover: Elevar y aumentar sombra */
        .sport-card-immersive:hover {
            transform: translateY(-10px) scale(1.02);
            box-shadow: 0 20px 40px rgba(0,0,0,0.2);
        }

        /* Imagen de Fondo con Efecto Zoom */
        .sport-card-immersive .card-bg {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background-size: cover;
            background-position: center;
            transition: transform 0.6s rgba(0,0,0,0.1);
            z-index: 1;
        }

        /* Zoom de la imagen al hacer hover */
        .sport-card-immersive:hover .card-bg {
            transform: scale(1.1);
        }

        /* Superposición de degradado para legibilidad del texto */
        .sport-card-immersive .card-overlay {
            position: absolute;
            bottom: 0;
            left: 0;
            width: 100%;
            height: 60%;
            background: linear-gradient(to top, rgba(15, 23, 42, 0.9), transparent);
            z-index: 2;
            transition: height 0.4s ease;
        }

        /* Contenido de la tarjeta (Texto e Iconos) */
        .sport-card-immersive .card-content {
            position: absolute;
            bottom: 0;
            left: 0;
            width: 100%;
            padding: 30px;
            z-index: 3;
            color: white;
        }

        /* Icono deportivo flotante */
        .sport-card-immersive .sport-icon {
            font-size: 2.5rem;
            margin-bottom: 15px;
            opacity: 0.9;
            display: inline-block;
            transition: transform 0.3s ease;
        }

        /* Animación del icono al hover */
        .sport-card-immersive:hover .sport-icon {
            transform: rotate(-10px) scale(1.1);
        }

        /* Texto de 'Acción' que aparece al hover */
        .sport-card-immersive .action-text {
            color: #27F5CC;
            font-weight: 800;
            text-transform: uppercase;
            letter-spacing: 1px;
            font-size: 0.8rem;
            opacity: 0;
            transform: translateY(10px);
            transition: all 0.3s ease 0.1s; /* Retraso ligero */
        }

        .sport-card-immersive:hover .action-text {
            opacity: 1;
            transform: translateY(0);
        }
</style>

<div class="container-fluid py-4">
    <div class="dashboard-container">

        <div class="row mb-5 align-items-center">
            <div class="col-md-8">
                <h1 class="display-4 fw-800 mb-2" style="letter-spacing: -2px; color: #0f172a;">
                    ¡Hola, <span style="color: #27F5CC;">@nombreUsuario</span>!
                </h1>
                <p class="lead text-muted fw-500 mb-0">
                    ¿Cuál es el desafío de hoy? Tu pasión te espera en la cancha.
                </p>
            </div>
        </div>

        <div class="row g-4 mb-5">

            <div class="col-md-4">
                <a asp-controller="Canchas" asp-action="Index" class="sport-card-immersive shadow-sm">
                    <div class="card-bg" style="background-image: url('https://images.unsplash.com/photo-1579952363873-27f3bade9f55?q=80&w=800&auto=format&fit=crop');"></div>
                    <div class="card-overlay"></div>
                    <div class="card-content">
                        <i class="bi bi-heptagon-fill sport-icon" style="color: #10b981;"></i>
                        <h3 class="fw-800 mb-1">Fútbol</h3>
                        <p class="small opacity-75 mb-3">Siente la adrenalina del gol en césped sintético profesional.</p>
                        <div class="action-text">Reservar experiencia <i class="bi bi-arrow-right"></i></div>
                    </div>
                </a>
            </div>

            <div class="col-md-4">
                <a asp-controller="Canchas" asp-action="Index" class="sport-card-immersive shadow-sm">
                    <div class="card-bg" style="background-image: url('https://images.unsplash.com/photo-1519861531473-9200262188bf?q=80&w=800&auto=format&fit=crop');"></div>
                    <div class="card-overlay"></div>
                    <div class="card-content">
                        <i class="bi bi-dribbble sport-icon" style="color: #f59e0b;"></i>
                        <h3 class="fw-800 mb-1">Básquet</h3>
                        <p class="small opacity-75 mb-3">Domina la duela y encesta como las estrellas de la NBA.</p>
                        <div class="action-text">Reservar experiencia <i class="bi bi-arrow-right"></i></div>
                    </div>
                </a>
            </div>

            <div class="col-md-4">
                <a asp-controller="Canchas" asp-action="Index" class="sport-card-immersive shadow-sm">
                    <div class="card-bg" style="background-image: url('https://images.unsplash.com/photo-1612872087720-bb876e2e67d1?q=80&w=800&auto=format&fit=crop');"></div>
                    <div class="card-overlay"></div>
                    <div class="card-content">
                        <i class="bi bi-vimeo sport-icon" style="color: #0ea5e9;"></i>
                        <h3 class="fw-800 mb-1">Vóley</h3>
                        <p class="small opacity-75 mb-3">Pura técnica y salto. El remate perfecto está a un clic.</p>
                        <div class="action-text">Reservar experiencia <i class="bi bi-arrow-right"></i></div>
                    </div>
                </a>
            </div>

        </div>

        <div class="row mt-5">
            <div class="col-12 text-center py-4 bg-white shadow-sm" style="border-radius: 20px; border-left: 5px solid #27F5CC;">
                <h5 class="fw-bold text-dark mb-0">
                    <i class="bi bi-rocket-takeoff-fill me-2 text-primary"></i>
                    Impulsando tu talento deportivo desde la <span style="color: #27F5CC;">ECUMEX</span>
                </h5>
            </div>
        </div>

    </div>
</div>