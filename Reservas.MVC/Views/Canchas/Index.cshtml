@model IEnumerable<Reserva.Modelos.Canchas>

@{
    ViewData["Title"] = "Canchas Disponibles";
}

<link rel="stylesheet" href="~/css/canchas-vivid.css" asp-append-version="true" />

<div class="bg-canchas-dinamico py-5">
    <div class="container">
        <header class="text-center mb-5">
            <h2 class="display-4" style="font-weight: 900; letter-spacing: -2px; color: #0f172a;">
                Canchas <span style="color: #27F5CC;">Disponibles</span>
            </h2>
            <p class="text-muted fs-5 fw-bold">RESERVA TU LUGAR EN LA VICTORIA</p>
        </header>

        <div class="row g-4">
            @if (Model != null && Model.Any())
            {
                @foreach (var cancha in Model)
                {
                    var tipo = cancha.Tipo_Canchas?.nombre_tip_cancha?.ToLower() ?? "general";

                    // Configuración de visualización basada en el tipo
                    string imgPath = tipo.Contains("fut") ? "/img/futbol.jpg" :
                    tipo.Contains("bas") ? "/img/basquet.jpg" :
                    tipo.Contains("voley") ? "/img/voley.jpg" : "/img/default.jpg";

                    string colorAccent = tipo.Contains("fut") ? "#10b981" :
                    tipo.Contains("bas") ? "#f59e0b" :
                    tipo.Contains("voley") ? "#0ea5e9" : "#64748b";

                    <div class="col-lg-4 col-md-6">
                        <div class="card card-sport-vivid border-0 shadow-sm h-100">

                            <div class="img-wrapper">
                                <img src="@imgPath" class="img-dynamic" alt="@cancha.nombre_cancha">
                                <div class="badge-float" style="border-left: 4px solid @colorAccent; color: #0f172a;">
                                    <span style="color: @colorAccent; margin-right: 5px;">●</span>
                                    @tipo.ToUpper()
                                </div>
                            </div>

                            <div class="card-body p-4 d-flex flex-column">
                                <h3 class="h4 fw-900 mb-2" style="color: #0f172a;">@cancha.nombre_cancha</h3>
                                <p class="text-muted small mb-4 flex-grow-1 fw-bold">
                                    @(cancha.descripcion_cancha ?? "Terreno de alta calidad para competencia profesional.")
                                </p>

                                <div class="mb-4">
                                    @if (cancha.estado_cancha)
                                    {
                                        <div class="d-inline-flex align-items-center px-3 py-1 rounded-pill" style="background: #ecfdf5; color: #059669; font-size: 0.7rem; font-weight: 900;">
                                            <i class="bi bi-check-circle-fill me-2"></i> DISPONIBLE
                                        </div>
                                    }
                                    else
                                    {
                                        <div class="d-inline-flex align-items-center px-3 py-1 rounded-pill" style="background: #fef2f2; color: #dc3545; font-size: 0.7rem; font-weight: 900;">
                                            <i class="bi bi-tools me-2"></i> MANTENIMIENTO
                                        </div>
                                    }
                                </div>

                                <div class="mt-auto">
                                    <a asp-controller="Reservas"
                                       asp-action="Create"
                                       asp-route-canchaId="@cancha.Id"
                                       class="btn-action-sport @(cancha.estado_cancha ? "" : "disabled")">
                                        <i class="bi bi-calendar-check fs-5"></i>
                                        <span>RESERVAR</span>
                                    </a>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            }
        </div>
    </div>
</div>