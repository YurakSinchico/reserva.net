@using Reserva.Modelos
@{
    ViewData["Title"] = "Gestión de Usuarios";
}

<div class="elec-page container mt-4 mb-5">
    <div class="row justify-content-center">
        <div class="col-md-10 col-lg-8">
            <div class="elec-card shadow-lg">
                <div class="elec-card-header text-center py-3 border-0">
                    <h3 class="mb-0 text-white fw-bold">
                        <i class="bi bi-person-plus-fill me-2"></i>Crear Nueva Cuenta
                    </h3>
                </div>

                ```
                <div class="elec-card-body p-4 p-md-5">
                    <form asp-action="Register" asp-controller="Account" method="post">

                        <div class="row">

                            <div class="col-md-6 border-end border-secondary pe-md-4">
                                <h5 class="elec-title mb-3 fs-5">
                                    <i class="bi bi-person-lines-fill me-2"></i>Datos Personales
                                </h5>

                                <div class="mb-3">
                                    <label class="form-label text-white-50 small fw-bold">Nombres</label>
                                    <input type="text" class="form-control elec-form-control rounded-3"
                                           name="nombre_cliente" required placeholder="Ej: Juan Alberto">
                                </div>

                                <div class="mb-3">
                                    <label class="form-label text-white-50 small fw-bold">Apellidos</label>
                                    <input type="text" class="form-control elec-form-control rounded-3"
                                           name="apellido_cliente" required placeholder="Ej: Pérez Castro">
                                </div>


                                <div class="mb-3">
                                    <label class="form-label text-white-50 small fw-bold">Fecha de Nacimiento</label>
                                    <input type="date" class="form-control elec-form-control rounded-3"
                                           name="fecha_nacimiento_cliente" required>
                                </div>
                            </div>


                            <div class="col-md-6 ps-md-4 mt-4 mt-md-0">
                                <h5 class="elec-title mb-3 fs-5">
                                    <i class="bi bi-card-heading me-2"></i>Contacto y Acceso
                                </h5>


                                <div class="mb-3">
                                    <label class="form-label text-white-50 small fw-bold">Correo Electrónico</label>
                                    <input type="email" class="form-control elec-form-control rounded-3"
                                           name="correo_cliente" required placeholder="usuario@ejemplo.com">
                                </div>

                                <div class="mb-3">
                                    <label class="form-label text-white-50 small fw-bold">Teléfono</label>
                                    <input type="text" class="form-control elec-form-control rounded-3"
                                           name="telefono_cliente" required placeholder="099-XXX-XXXX">
                                </div>


                                <div class="mb-3">
                                    <label class="form-label text-white-50 small fw-bold">Contraseña</label>
                                    <input type="password" class="form-control elec-form-control rounded-3"
                                           name="contrasena_cliente" required placeholder="Mínimo 8 caracteres">
                                </div>
                            </div>
                        </div>

                        <hr class="my-4 border-secondary opacity-50">

                        <div class="d-grid gap-2 mt-4">
                            <button type="submit" class="btn elec-btn elec-btn-primary btn-lg rounded-3 fw-bold shadow-sm">
                                <i class="bi bi-person-check-fill me-2"></i>Crear Usuario
                            </button>
                            <a asp-action="Index" asp-controller="Home" class="btn elec-btn elec-btn-secondary rounded-3">
                                Cancelar
                            </a>
                        </div>

                        @if (ViewBag.ErrorMessage != null)
                        {
                            <div class="alert elec-alert elec-alert-danger mt-3 text-center border-0 shadow-sm">
                                <i class="bi bi-exclamation-octagon-fill me-2"></i>@ViewBag.ErrorMessage
                            </div>
                        }
                    </form>
                </div>
            </div>
        </div>
    </div>
    ```

</div>
