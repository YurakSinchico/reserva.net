@using Reserva.Modelos
@model Reservas

@{
    // Obtener nombre de la cancha para el diseño
    var nombreCancha = ((IEnumerable<SelectListItem>)ViewBag.Canchas)
                        .FirstOrDefault(x => x.Value == Model.CanchasId.ToString())?.Text
                        ?? "Cancha Deportiva";
}

@* Referencia al archivo de estilos externo *@
<link rel="stylesheet" href="~/css/reserva-estilos.css" />

<div class="reserva-page-container">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-lg-5">

                <div class="card reserva-card">
                    <div class="card-header reserva-header text-center text-white">
                        <h3 class="fw-bold mb-1">Nueva Reserva</h3>
                        <p class="mb-0 opacity-75 small">Cancha: <strong>@nombreCancha</strong></p>
                    </div>

                    <div class="card-body p-4 p-md-5">
                        <form asp-action="Create" method="post">
                            @Html.AntiForgeryToken()
                            <input type="hidden" asp-for="CanchasId" />

                            <div class="mb-4">
                                <label class="form-label fw-bold text-secondary small">1. FECHA DE RESERVA</label>
                                <div class="input-group reserva-input-group">
                                    <input type="date" asp-for="fecha_reserva" class="form-control border-0 bg-transparent"
                                           required min="@DateTime.Now.ToString("yyyy-MM-dd")"
                                           value="@Model.fecha_reserva.ToString("yyyy-MM-dd")" />
                                    <button type="submit" name="enviar" value="Ver turnos" class="btn btn-dark px-4">
                                        Ver turnos
                                    </button>
                                </div>
                            </div>

                            <div class="mb-5">
                                <label class="form-label fw-bold text-secondary small">2. HORARIOS DISPONIBLES</label>
                                <div class="input-group reserva-input-group">
                                    <select asp-for="HorariosId" class="form-select border-0 bg-transparent" required>
                                        <option value="">-- Seleccione el turno --</option>
                                        @if (ViewBag.Horarios != null)
                                        {
                                            foreach (var h in (IEnumerable<Horarios>)ViewBag.Horarios)
                                            {
                                                <option value="@h.Id">@h.hora_inicio.ToString(@"HH\:mm") - @h.hora_fin.ToString(@"HH\:mm")</option>
                                            }
                                        }
                                    </select>
                                </div>
                            </div>

                            <button type="submit" name="enviar" value="CONFIRMAR MI RESERVA" class="btn btn-primary w-100 reserva-btn-confirmar">
                                Confirmar mi Reserva
                            </button>
                        </form>
                    </div>
                </div>

            </div>
        </div>
    </div>
</div>