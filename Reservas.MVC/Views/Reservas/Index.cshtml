@using System.Security.Claims
@model IEnumerable<Reserva.Modelos.Reservas>
@{
    ViewData["Title"] = "Mis Reservas";
    var adminEmail = "yurianrango3@gmail.com";
    var userEmail = User.FindFirstValue(System.Security.Claims.ClaimTypes.Email);
}

<div class="container mt-4">
    @* Alerta de error (solo si intentan hackear la URL) *@
    @if (TempData["ErrorPermiso"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show shadow-sm mb-4" role="alert">
            <i class="bi bi-exclamation-octagon-fill me-2"></i> @TempData["ErrorPermiso"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="card shadow border-0" style="border-radius: 16px; overflow: hidden;">
        <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center py-3">
            <h4 class="mb-0 fw-bold">Historial de Reservas</h4>

            @* Solo tú (Admin) ves este botón *@
            @if (userEmail == adminEmail)
            {
                <a asp-action="Create" class="btn btn-light btn-sm fw-bold shadow-sm">
                    <i class="bi bi-plus-lg me-1"></i> Nueva Reserva
                </a>
            }
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th class="ps-4">Fecha</th>
                            <th>Cancha</th>
                            <th>Horario</th>
                            <th>Cliente</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model != null && Model.Any())
                        {
                            @* AQUÍ VA EL CÓDIGO QUE PREGUNTASTE *@
                            @foreach (var item in Model)
                            {
                                <tr>
                                    <td class="ps-4">@item.fecha_reserva.ToShortDateString()</td>
                                    <td>
                                        <span class="badge bg-info text-dark">
                                            @(item.Canchas?.nombre_cancha ?? "Cancha #" + item.CanchasId)
                                        </span>
                                    </td>
                                    <td>
                                        <i class="bi bi-clock me-1 text-primary"></i>
                                        @(item.Horarios?.hora_inicio.ToString(@"HH\:mm") ?? "N/A")
                                    </td>
                                    <td>
                                        <i class="bi bi-person-circle me-1"></i>
                                        <strong>@(item.Clientes?.nombre_cliente ?? "Usuario " + item.ClientesId)</strong>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="4" class="text-center py-5 text-muted">
                                    <i class="bi bi-calendar-x d-block mb-2" style="font-size: 2rem;"></i>
                                    No hay reservas registradas.
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>