@using System.Security.Claims
@{
    var adminEmail = "yurianrango3@gmail.com";
    var userEmail = User.FindFirstValue(ClaimTypes.Email);
    var isAdmin = User.Identity.IsAuthenticated && userEmail == adminEmail;
    var currentCtrl = ViewContext.RouteData.Values["Controller"]?.ToString();
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Reserva.NET</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;600;800&display=swap" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
</head>
<body>

    <aside class="sidebar-wrapper">
        <a class="brand-logo" asp-controller="Home" asp-action="Index">
            <div style="width: 40px; height: 40px; background: #27F5CC; border-radius: 12px; display: grid; place-items: center; color: #0f172a; box-shadow: 0 8px 15px rgba(39,245,204,0.3);">
                <i class="bi bi-lightning-charge-fill"></i>
            </div>
            <span>Reserva<span style="color: #27F5CC;">.</span>NET</span>
        </a>

        <nav class="nav flex-column flex-grow-1">
            <a class="nav-link-vivid @(currentCtrl == "Home" ? "active" : "")" asp-controller="Home" asp-action="Index">
                <i class="bi bi-house-door me-3"></i> Dashboard
            </a>
            <a class="nav-link-vivid @(currentCtrl == "Canchas" && ViewContext.RouteData.Values["Action"]?.ToString() == "Index" ? "active" : "")" asp-controller="Canchas" asp-action="Index">
                <i class="bi bi-trophy me-3"></i> Canchas
            </a>

            @if (isAdmin)
            {
                <div class="mt-4 mb-2 px-3 small text-muted fw-bold" style="letter-spacing: 1px;">SISTEMA</div>
                <a class="nav-link-vivid @(currentCtrl == "Canchas" && ViewContext.RouteData.Values["Action"]?.ToString() == "Admin" ? "active" : "")" asp-controller="Canchas" asp-action="Admin">
                    <i class="bi bi-layers me-3"></i> Panel Admin
                </a>
                <a class="nav-link-vivid" asp-controller="Horarios" asp-action="Index">
                    <i class="bi bi-clock me-3"></i> Horarios
                </a>
                <a class="nav-link-vivid" asp-controller="Reservas" asp-action="Index">
                    <i class="bi bi-calendar-check me-3"></i> Reservas
                </a>
            }
        </nav>

        <div class="mt-auto">
            @if (User.Identity.IsAuthenticated)
            {
                <div class="p-3 rounded-4" style="background: rgba(39,245,204,0.1); border: 1px solid rgba(39,245,204,0.2);">
                    <div class="d-flex align-items-center mb-3">
                        <div class="bg-white rounded-circle p-2 shadow-sm me-3">⚽</div>
                        <div class="overflow-hidden">
                            <p class="m-0 fw-bold small text-truncate">@User.Identity.Name</p>
                            <span class="text-muted" style="font-size: 0.7rem;">Ingeniería Software</span>
                        </div>
                    </div>
                    <form asp-controller="Account" asp-action="Logout" method="post" class="m-0">
                        <button type="submit" class="btn btn-sm w-100 fw-bold" style="color: #ef4444; background: #fef2f2; border-radius: 12px; border: none;">
                            <i class="bi bi-box-arrow-right me-2"></i> Salir
                        </button>
                    </form>
                </div>
            }
            else
            {
                <a class="btn w-100 fw-bold py-2" style="background: #27F5CC; color: #0f172a; border-radius: 15px;" asp-controller="Account" asp-action="Index">
                    Iniciar Sesión
                </a>
            }
        </div>
    </aside>

    <main class="main-content">
        <div class="container-fluid">
            @RenderBody()
        </div>

        <footer class="footer-vivid">
            <div class="fw-bold text-muted small">© 2026 <span style="color: #27F5CC;">Reserva.NET</span></div>
            <div class="d-flex gap-4 small fw-bold text-muted">
                <span>ESTUDIANTE DE SOFTWARE</span>
            </div>
        </footer>
    </main>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @RenderSection("Scripts", required: false)
</body>
</html>