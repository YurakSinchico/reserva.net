@model IEnumerable<Reserva.Modelos.Reservas>
@{
    var canchas = ViewBag.Canchas as List<Reserva.Modelos.Canchas>;
    var horarios = ViewBag.Horarios as List<Reserva.Modelos.Horarios>;
    var clientes = ViewBag.Clientes as List<Reserva.Modelos.Clientes>;
}

<div class="container-fluid mt-4">
    <div class="card reserva-card">
        <div class="card-header bg-dark py-3">
            <h5 class="text-white mb-0 fw-bold">
                <i class="bi bi-calendar3 me-2 text-info"></i> Historial de Reservas
            </h5>
        </div>

        <div class="card-body p-0">
            <table class="table table-hover align-middle mb-0 table-reserva">
                <thead>
                    <tr>
                        <th class="ps-4">Fecha</th>
                        <th>Cancha</th>
                        <th>Horario</th>
                        <th>Cliente</th>
                        <th class="text-center">Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        foreach (var item in Model)
                        {
                            var cliente = clientes?.FirstOrDefault(c => c.Id == item.ClientesId);
                            var nombre = cliente?.nombre_cliente ?? "Usuario";

                            <tr>
                                <td class="ps-4 fw-bold">@item.fecha_reserva.ToString("dd/MM/yyyy")</td>
                                <td>
                                    <span class="badge-cancha">
                                        <i class="bi bi-trophy-fill"></i>
                                        @(canchas?.FirstOrDefault(c => c.Id == item.CanchasId)?.nombre_cancha ?? "Cancha")
                                    </span>
                                </td>
                                <td class="text-primary">
                                    <i class="bi bi-clock"></i>
                                    @(horarios?.FirstOrDefault(h => h.Id == item.HorariosId)?.hora_inicio.ToString(@"HH\:mm") ?? "00:00")
                                </td>
                                <td>
                                    <div class="d-flex align-items-center">
                                        <div class="avatar-cliente">@nombre.Substring(0, 1).ToUpper()</div>
                                        <span class="small fw-bold">@nombre</span>
                                    </div>
                                </td>
                                <td class="text-center">
                                    <form asp-action="Cancelar" method="post">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@item.Id" />
                                        <button type="submit" class="btn btn-outline-danger btn-sm btn-cancelar">
                                            <i class="bi bi-trash"></i> Cancelar
                                        </button>
                                    </form>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="5" class="text-center py-5 text-muted">
                                No hay reservas registradas actualmente.
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>