@model IEnumerable<Reserva.Modelos.Canchas>

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center my-4">
        <h2 class="fw-bold">Gestión de Inventario</h2>
        <a asp-action="Create" class="btn btn-dark btn-modern">
            <i class="bi bi-plus-lg me-2"></i>Nueva Cancha
        </a>
    </div>

    <div class="bg-white p-3 rounded-4 shadow-sm">
        <table class="table align-middle">
            <thead class="text-muted small text-uppercase">
                <tr>
                    <th>Cancha</th>
                    <th>Tipo</th>
                    <th>Estado</th>
                    <th class="text-end">Acciones</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>
                            <div class="fw-bold">@item.nombre_cancha</div>
                            <div class="small text-muted">ID: @item.Id</div>
                        </td>
                        <td>
                            <span class="badge border text-dark fw-normal">@item.Tipo_Canchas?.nombre_tip_cancha</span>
                        </td>
                        <td>
                            <div class="form-check form-switch">
                                <input class="form-check-input" type="checkbox" @(item.estado_cancha ? "checked" : "") disabled>
                            </div>
                        </td>
                        <td class="text-end">
                            <div class="d-flex justify-content-end gap-2">
                                <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-light btn-sm rounded-3">
                                    <i class="bi bi-pencil text-primary"></i>
                                </a>

                                @* Cambiamos el submit por un botón normal con una clase para el script *@
                                <form asp-action="Delete" asp-route-id="@item.Id" method="post" class="d-inline form-eliminar">
                                    <button type="button" class="btn btn-light btn-sm rounded-3 btn-delete">
                                        <i class="bi bi-trash text-danger"></i>
                                    </button>
                                </form>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@section Scripts {
    <script>
        // Escuchamos el clic en los botones de borrar
        $('.btn-delete').on('click', function (e) {
            var form = $(this).closest('form'); // Buscamos el formulario padre

            Swal.fire({
                title: '¿Estás seguro?',
                text: "Esta acción eliminará la cancha permanentemente",
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#d33', // Rojo para eliminar
                cancelButtonColor: '#6c757d',
                confirmButtonText: 'Sí, eliminar',
                cancelButtonText: 'Cancelar',
                reverseButtons: true,
                borderRadius: '1.25rem' // Para que combine con tus rounded-4
            }).then((result) => {
                if (result.isConfirmed) {
                    form.submit(); // Si confirma, enviamos el formulario
                }
            })
        });
    </script>
}