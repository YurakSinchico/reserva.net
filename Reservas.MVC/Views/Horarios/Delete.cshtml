@model Reserva.Modelos.Horarios

@{
    ViewData["Title"] = "Eliminar Horario";
}

<style>
    /* Contenedor con degradado de advertencia suave */
    .delete-header-bg {
        background: linear-gradient(to bottom, #fff5f5 0%, #ffffff 100%);
        border-bottom: 1px solid rgba(239, 68, 68, 0.1);
    }

    /* Icono con animación de latido sutil en CSS */
    .heartbeat-icon {
        display: inline-block;
        animation: heartbeat 1.5s ease-in-out infinite;
        color: #ef4444;
        font-size: 4.5rem;
    }

    @@keyframes heartbeat {
        0% {
            transform: scale(1);
        }

        14% {
            transform: scale(1.1);
        }

        28% {
            transform: scale(1);
        }

        42% {
            transform: scale(1.1);
        }

        70% {
            transform: scale(1);
        }
    }

    /* Tarjeta inmersiva de peligro */
    .card-delete-schedule {
        border-radius: 30px;
        border: none;
        box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.08);
        overflow: hidden;
    }

    /* Botón de acción crítica */
    .btn-critical {
        background: #ef4444;
        color: white;
        border: none;
        border-radius: 16px;
        padding: 18px;
        font-weight: 800;
        transition: all 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
    }

        .btn-critical:hover {
            background: #dc2626;
            transform: scale(1.02);
            box-shadow: 0 10px 20px rgba(239, 68, 68, 0.2);
            color: white;
        }

    .time-badge-delete {
        background: #0f172a;
        color: #27F5CC;
        padding: 15px 25px;
        border-radius: 20px;
        display: inline-block;
        font-size: 1.5rem;
        font-weight: 800;
        box-shadow: 0 8px 15px rgba(15, 23, 42, 0.1);
    }
</style>

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-5 col-md-8">

            <div class="card card-delete-schedule bg-white">
                @* Cabecera de Alerta *@
                <div class="delete-header-bg py-5 text-center">
                    <div class="mb-3">
                        <i class="bi bi-calendar-x-fill heartbeat-icon"></i>
                    </div>
                    <h2 class="fw-800 text-dark mb-1">¿Remover Turno?</h2>
                    <p class="text-muted small px-5">Confirma que deseas eliminar este bloque de tiempo del sistema.</p>
                </div>

                <div class="card-body p-4 p-md-5 text-center">
                    @* Información del Horario *@
                    <div class="mb-4">
                        <span class="text-uppercase small fw-800 text-muted d-block mb-3" style="letter-spacing: 1.5px;">Rango Horario</span>
                        <div class="time-badge-delete mb-2">
                            @Model.hora_inicio.ToString(@"hh\:mm") — @Model.hora_fin.ToString(@"hh\:mm")
                        </div>
                        <div class="mt-2 text-muted">
                            <small class="fw-bold">ID Registro: #@Model.Id</small>
                        </div>
                    </div>

                    @* Formulario de Eliminación *@
                    <form asp-action="Delete" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" asp-for="Id" />

                        <div class="d-grid gap-3">
                            <button type="submit" class="btn btn-critical">
                                <i class="bi bi-trash3-fill me-2"></i> CONFIRMAR ELIMINACIÓN
                            </button>

                            <a asp-action="Index" class="btn btn-link text-decoration-none text-muted fw-bold">
                                No, mantener este turno
                            </a>
                        </div>
                    </form>

                    @* Validación de errores del servidor *@
                    @if (!ViewData.ModelState.IsValid)
                    {
                        <div class="alert alert-danger mt-4 rounded-4 border-0 shadow-sm small">
                            <i class="bi bi-info-circle-fill me-2"></i>
                            <div asp-validation-summary="All" class="d-inline"></div>
                        </div>
                    }
                </div>

                @* Pie de tarjeta sutil *@
                <div class="bg-light py-3 text-center border-top">
                    <small class="text-muted">
                        <i class="bi bi-shield-lock me-1"></i> Acción protegida por administrador
                    </small>
                </div>
            </div>

        </div>
    </div>
</div>