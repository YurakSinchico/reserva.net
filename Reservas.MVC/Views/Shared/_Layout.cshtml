@using System.Security.Claims

@{
    var adminEmail = "yurianrango3@gmail.com";
    var userEmail = User.FindFirstValue(ClaimTypes.Email);
    var isAdmin = User.Identity.IsAuthenticated && userEmail == adminEmail;
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Reservas Deportivas</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />

 
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet">
</head>

<body>

    <header>
        <nav class="navbar navbar-expand-lg navbar-dark bg-dark shadow">
            <div class="container">

                <a class="navbar-brand fw-bold text-warning" asp-controller="Home" asp-action="Index">
                    ⚽ Reservas Deportivas
                </a>

                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#menu">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse" id="menu">
                    <ul class="navbar-nav me-auto">

                        @if (User.Identity.IsAuthenticated)
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Home" asp-action="Index">Inicio</a>
                            </li>

                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Canchas" asp-action="Index">Canchas</a>
                            </li>

                            @* *@
                            @if (isAdmin)
                            {
                                <li class="nav-item">
                                    <a class="nav-link text-warning fw-bold" asp-controller="Canchas" asp-action="Admin">
                                        <i class="bi bi-shield-lock"></i> Panel Admin
                                    </a>
                                </li>

                                <li class="nav-item">
                                    <a class="nav-link" asp-controller="Horarios" asp-action="Index">
                                        <i class="bi bi-clock"></i> Horarios
                                    </a>
                                </li>

                                <li class="nav-item">
                                    <a class="nav-link" asp-controller="Reservas" asp-action="Index">
                                        <i class="bi bi-calendar-check"></i> Reservas
                                    </a>
                                </li>
                            }
                            else
                            {
                                @*  *@
                                <li class="nav-item">
                                    <a class="nav-link text-success" asp-controller="Reservas" asp-action="Create">
                                        <i class="bi bi-plus-circle"></i> Reservar
                                    </a>
                                </li>

                                <li class="nav-item">
                                    <a class="nav-link" asp-controller="Reservas" asp-action="MisReservas">
                                        <i class="bi bi-list-check"></i> Mis Reservas
                                    </a>
                                </li>
                            }
                        }
                    </ul>

                    <ul class="navbar-nav">
                        @if (User.Identity.IsAuthenticated)
                        {
                            <li class="nav-item">
                                <span class="nav-link text-info fw-bold">
                                    <i class="bi bi-person-circle"></i> @User.Identity.Name
                                </span>
                            </li>

                            <li class="nav-item">
                                <form asp-controller="Account" asp-action="Logout" method="post">
                                    <button class="btn btn-danger btn-sm ms-2">
                                        <i class="bi bi-box-arrow-right"></i> Salir
                                    </button>
                                </form>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item">
                                <a class="btn btn-primary" asp-controller="Account" asp-action="Index">
                                    <i class="bi bi-box-arrow-in-right"></i> Iniciar Sesión
                                </a>
                            </li>
                        }
                    </ul>

                </div>
            </div>
        </nav>
    </header>

    <div class="container mt-4">
        <main role="main">
            @RenderBody()
        </main>
    </div>

    <footer class="bg-dark text-white text-center mt-5 p-3">
        <small>© 2026 - Sistema de Reservas Deportivas ⚽</small>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>

    @RenderSection("Scripts", required: false)

</body>
</html>