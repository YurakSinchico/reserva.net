@model Reserva.Modelos.Clientes
@{
    ViewData["Title"] = "Crear Cuenta - ECUMEX";
    Layout = null;
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;600;800&display=swap" rel="stylesheet">

    @* Estilos externos *@
    <link rel="stylesheet" href="~/css/register-vivid.css" asp-append-version="true" />
</head>
<body>

    <div class="elec-card shadow-lg">
        <div class="elec-card-header text-center">
            <i class="bi bi-person-plus-fill" style="color: #27F5CC; font-size: 3.5rem;"></i>
            <h2 class="fw-900 mt-2 mb-0">ÚNETE A <span style="color: #27F5CC;">ECUMEX</span></h2>
            <p class="text-white-50 small fw-bold mt-1">ESTÁS A UN PASO DE TU PRÓXIMO PARTIDO</p>
        </div>

        <div class="elec-card-body p-4 p-md-5">
            <form asp-action="Register" asp-controller="Account" method="post">
                <div class="row">
                    @* Columna de Datos Personales *@
                    <div class="col-md-6 border-end pe-md-4">
                        <h5 class="elec-title fs-6 small">Datos Personales</h5>
                        <div class="mb-3">
                            <label class="small fw-800 text-muted mb-1">NOMBRES</label>
                            <input type="text" name="nombre_cliente" class="form-control elec-form-control" placeholder="Ej. Juan Alberto" required>
                        </div>
                        <div class="mb-3">
                            <label class="small fw-800 text-muted mb-1">APELLIDOS</label>
                            <input type="text" name="apellido_cliente" class="form-control elec-form-control" placeholder="Ej. Pérez Castro" required>
                        </div>
                        <div class="mb-3">
                            <label class="small fw-800 text-muted mb-1">FECHA DE NACIMIENTO</label>
                            <input type="date" name="fecha_nacimiento_cliente" class="form-control elec-form-control" required>
                        </div>
                    </div>

                    @* Columna de Contacto y Acceso *@
                    <div class="col-md-6 ps-md-4 mt-4 mt-md-0">
                        <h5 class="elec-title fs-6 small">Contacto y Acceso</h5>
                        <div class="mb-3">
                            <label class="small fw-800 text-muted mb-1">CORREO ELECTRÓNICO</label>
                            <input type="email" name="correo_cliente" class="form-control elec-form-control" placeholder="usuario@ejemplo.com" required>
                        </div>
                        <div class="mb-3">
                            <label class="small fw-800 text-muted mb-1">TELÉFONO</label>
                            <input type="text" name="telefono_cliente" class="form-control elec-form-control" placeholder="099-XXX-XXXX" required>
                        </div>
                        <div class="mb-3">
                            <label class="small fw-800 text-muted mb-1">CONTRASEÑA</label>
                            <input type="password" name="contrasena_cliente" class="form-control elec-form-control" placeholder="Mínimo 8 caracteres" required>
                        </div>
                    </div>
                </div>

                @* Sección de Botones de Acción *@
                <div class="row mt-5 g-3">
                    <div class="col-md-6 order-2 order-md-1">
                        @* Corrección: Apunta a la acción Index para evitar el error 404 *@
                        <a asp-action="Index" asp-controller="Account" class="btn-cancel text-center d-block" style="text-decoration: none;">VOLVER AL LOGIN</a>
                    </div>
                    <div class="col-md-6 order-1 order-md-2">
                        <button type="submit" class="btn-register w-100">REGISTRAR MI CUENTA</button>
                    </div>
                </div>
            </form>
        </div>
    </div>

</body>
</html>