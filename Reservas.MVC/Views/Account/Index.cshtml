@model Reserva.Modelos.Clientes
@{
    ViewData["Title"] = "Iniciar Sesión";
    Layout = null;
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - ECUMEX</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;600;800&display=swap" rel="stylesheet">

    @* Llamada al archivo de estilos externo *@
    <link rel="stylesheet" href="~/css/login-vivid.css" asp-append-version="true" />
</head>
<body>

    <div class="glass-card">
        <div class="text-center mb-4">
            <div class="brand-badge">
                <i class="bi bi-lightning-charge-fill fs-3"></i>
            </div>
            <h2 class="elec-title mb-1">ECU<span style="color: #27F5CC;">MEX</span></h2>
            <p class="text-muted small fw-bold">TU PRÓXIMA VICTORIA EMPIEZA AQUÍ</p>
        </div>

        <form asp-action="Login" asp-controller="Account" method="post">
            <div class="mb-3">
                <label class="form-label fw-900 small text-uppercase" style="color: #475569; letter-spacing: 0.5px;">
                    <i class="bi bi-envelope me-2"></i>Usuario / Correo
                </label>
                <input type="text" class="form-control elec-form-control"
                       name="username" required placeholder="Ingresa tu usuario">
            </div>

            <div class="mb-4">
                <label class="form-label fw-900 small text-uppercase" style="color: #475569; letter-spacing: 0.5px;">
                    <i class="bi bi-key me-2"></i>Contraseña
                </label>
                <input type="password" class="form-control elec-form-control"
                       name="password" required placeholder="••••••••">
            </div>

            <button type="submit" class="elec-btn-primary w-100 mb-3 shadow-sm">
                <i class="bi bi-box-arrow-in-right me-2"></i>INGRESAR AL SISTEMA
            </button>

            @if (ViewBag.ErrorMessage != null)
            {
                <div class="alert alert-danger text-center border-0 small py-2 rounded-3 fw-bold">
                    <i class="bi bi-exclamation-octagon-fill me-2"></i>@ViewBag.ErrorMessage
                </div>
            }
        </form>

        <div class="text-center mt-4 pt-3 border-top">
            <p class="text-muted small mb-1 fw-bold">¿AÚN NO TIENES CUENTA?</p>
            <a asp-action="Register" asp-controller="Account" class="text-info-custom small text-uppercase">
                Regístrate aquí <i class="bi bi-arrow-right ms-1"></i>
            </a>
        </div>
    </div>

</body>
</html>