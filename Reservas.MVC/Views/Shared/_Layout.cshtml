@using System.Security.Claims
@{
    var adminEmail = "yurianrango3@gmail.com";
    var userEmail = User.FindFirstValue(ClaimTypes.Email);
    var isAdmin = User.Identity.IsAuthenticated && userEmail == adminEmail;
    var currentCtrl = ViewContext.RouteData.Values["Controller"]?.ToString();
}

<!DOCTYPE html>
<html lang="es" class="h-100">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Reserva.NET</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;600;800&display=swap" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    <style>
        body {
            font-family: 'Plus Jakarta Sans', sans-serif;
            background-color: #f8fafc;
        }

        .sidebar-wrapper {
            background: #ffffff;
            border-right: 1px solid rgba(0,0,0,0.05);
            width: 280px;
            height: 100vh;
            position: fixed;
            padding: 2rem 1.5rem;
            display: flex;
            flex-column: column;
            z-index: 1000;
        }

        .main-content {
            margin-left: 280px;
            min-height: 100vh;
            display: flex;
            flex-direction: column;
        }

        .brand-logo {
            font-size: 1.5rem;
            font-weight: 800;
            color: #0f172a;
            text-decoration: none;
            display: flex;
            align-items: center;
            gap: 12px;
            margin-bottom: 3rem;
        }

        .nav-link-vivid {
            color: #64748b;
            border-radius: 12px;
            padding: 12px 18px;
            margin-bottom: 5px;
            transition: all 0.3s ease;
            font-weight: 600;
            display: flex;
            align-items: center;
            text-decoration: none;
        }

            .nav-link-vivid:hover {
                background: #f1f5f9;
                color: #0f172a;
                transform: translateX(5px);
            }

            .nav-link-vivid.active {
                background: #27F5CC;
                color: #0f172a !important;
                box-shadow: 0 10px 20px rgba(39, 245, 204, 0.2);
            }

        /* Footer Estilo Cápsula */
        .footer-capsule {
            background: white;
            border-radius: 20px;
            box-shadow: 0 4px 15px rgba(0,0,0,0.05);
            padding: 1rem 2rem;
            margin-bottom: 2rem;
        }
    </style>
</head>
<body class="d-flex flex-column h-100">

    <aside class="sidebar-wrapper">
        <a class="brand-logo" asp-controller="Home" asp-action="Index">
            <div style="width: 40px; height: 40px; background: #27F5CC; border-radius: 12px; display: grid; place-items: center; color: #0f172a; box-shadow: 0 8px 15px rgba(39,245,204,0.3);">
                <i class="bi bi-lightning-charge-fill"></i>
            </div>
            <span>Reserva<span style="color: #27F5CC;">.</span>NET</span>
        </a>

        <nav class="nav flex-column flex-grow-1">
            <a class="nav-link-vivid @(currentCtrl == "Home" ? "active" : "")" asp-controller="Home" asp-action="Index">
                <i class="bi bi-grid-1x2-fill me-3"></i> Dashboard
            </a>
            <a class="nav-link-vivid @(currentCtrl == "Canchas" && ViewContext.RouteData.Values["Action"]?.ToString() == "Index" ? "active" : "")" asp-controller="Canchas" asp-action="Index">
                <i class="bi bi-trophy-fill me-3"></i> Canchas
            </a>

            @if (User.Identity.IsAuthenticated && !isAdmin)
            {
                <a class="nav-link-vivid @(currentCtrl == "Reservas" ? "active" : "")" asp-controller="Reservas" asp-action="Index">
                    <i class="bi bi-calendar-heart-fill me-3"></i> Mis Reservas
                </a>
            }

            @if (isAdmin)
            {
                <div class="mt-4 mb-2 px-3 small text-muted fw-bold" style="letter-spacing: 1px;">SISTEMA</div>

                <a class="nav-link-vivid @(currentCtrl == "Canchas" && ViewContext.RouteData.Values["Action"]?.ToString() == "Admin" ? "active" : "")" asp-controller="Canchas" asp-action="Admin">
                    <i class="bi bi-layers-half me-3"></i> Panel Admin
                </a>

                <a class="nav-link-vivid @(currentCtrl == "Horarios" ? "active" : "")" asp-controller="Horarios" asp-action="Index">
                    <i class="bi bi-clock-history me-3"></i> Horarios
                </a>

                <a class="nav-link-vivid @(currentCtrl == "Reservas" ? "active" : "")" asp-controller="Reservas" asp-action="Index">
                    <i class="bi bi-kanban-fill me-3"></i> Gestión Reservas
                </a>
            }
        </nav>

        <div class="mt-auto">
            @if (User.Identity.IsAuthenticated)
            {
                <div class="p-3 rounded-4" style="background: #f8fafc; border: 1px solid #e2e8f0;">
                    <div class="d-flex align-items-center mb-3">
                        <div class="bg-primary text-white rounded-circle p-2 shadow-sm me-3" style="width: 40px; height: 40px; display: grid; place-items: center;">
                            <i class="bi bi-person-fill"></i>
                        </div>
                        <div class="overflow-hidden">
                            <p class="m-0 fw-bold small text-truncate text-dark">@User.Identity.Name</p>
                            <span class="text-success fw-bold" style="font-size: 0.65rem; text-transform: uppercase;">Activo Now</span>
                        </div>
                    </div>
                    <form asp-controller="Account" asp-action="Logout" method="post" class="m-0">
                        <button type="submit" class="btn btn-sm w-100 fw-bold" style="color: #ef4444; background: #fef2f2; border-radius: 12px; border: none; padding: 10px;">
                            <i class="bi bi-box-arrow-right me-2"></i> Cerrar Sesión
                        </button>
                    </form>
                </div>
            }
        </div>
    </aside>

    <main class="main-content">
        <div class="container-fluid py-4 flex-grow-1">
            @RenderBody()
        </div>

        @* --- FOOTER NUEVO Y CREATIVO --- *@
        <footer class="footer mt-auto py-4">
            <div class="container-fluid px-4">
                <div class="footer-capsule d-flex flex-column flex-md-row justify-content-between align-items-center">
                    <div class="mb-2 mb-md-0">
                        <span class="fw-800 text-dark">© 2026 <span style="color: #27F5CC;">Reserva.NET</span></span>
                        <span class="text-muted ms-2 small">| Premium Experience</span>
                    </div>

                    <div class="d-flex gap-4 fs-5">
                        <a href="#" class="text-dark opacity-75 hover-opacity-100"><i class="bi bi-facebook"></i></a>
                        <a href="#" class="text-dark opacity-75 hover-opacity-100"><i class="bi bi-instagram"></i></a>
                        <a href="#" class="text-dark opacity-75 hover-opacity-100"><i class="bi bi-whatsapp"></i></a>
                    </div>

                    <div class="d-none d-md-block">
                        <span class="badge bg-light text-dark px-3 py-2 border" style="border-radius: 10px; font-weight: 600;">
                            <i class="bi bi-shield-lock-fill text-primary me-2"></i>Conexión Encriptada
                        </span>
                    </div>
                </div>
            </div>
        </footer>
    </main>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>