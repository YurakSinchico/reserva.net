@model IEnumerable<Reserva.Modelos.Canchas>
@{
    ViewData["Title"] = "Tu Portal Deportivo";
    var nombreUsuario = User.Identity?.Name ?? "Deportista";
}

@* Enlace al archivo de estilos externo *@
<link rel="stylesheet" href="~/css/dashboard-vivid.css" asp-append-version="true" />

<div class="container-fluid py-4">
    <div class="dashboard-container">

        @* Bienvenida *@
        <div class="row mb-5 align-items-center">
            <div class="col-md-8">
                <h1 class="display-4 fw-900 mb-2" style="letter-spacing: -2px; color: #0f172a;">
                    ¡Hola, <span style="color: #27F5CC;">@nombreUsuario</span>!
                </h1>
                <p class="lead text-muted fw-bold mb-0">
                    ¿Cuál es el desafío de hoy? Tu pasión te espera en la cancha.
                </p>
            </div>
        </div>

        @* Tarjetas de Categorías Deportivas *@
        <div class="row g-4 mb-5">

            <div class="col-md-4">
                <a asp-controller="Canchas" asp-action="Index" class="sport-card-immersive">
                    <div class="card-bg" style="background-image: url('https://images.unsplash.com/photo-1579952363873-27f3bade9f55?q=80&w=800&auto=format&fit=crop');"></div>
                    <div class="card-overlay"></div>
                    <div class="card-content">
                        <i class="bi bi-heptagon-fill sport-icon" style="color: #10b981;"></i>
                        <h3 class="fw-900 mb-1">Fútbol</h3>
                        <p class="small opacity-75 mb-3">Siente la adrenalina del gol en césped sintético profesional.</p>
                        <div class="action-text">Reservar experiencia <i class="bi bi-arrow-right"></i></div>
                    </div>
                </a>
            </div>

            <div class="col-md-4">
                <a asp-controller="Canchas" asp-action="Index" class="sport-card-immersive">
                    <div class="card-bg" style="background-image: url('https://images.unsplash.com/photo-1519861531473-9200262188bf?q=80&w=800&auto=format&fit=crop');"></div>
                    <div class="card-overlay"></div>
                    <div class="card-content">
                        <i class="bi bi-dribbble sport-icon" style="color: #f59e0b;"></i>
                        <h3 class="fw-900 mb-1">Básquet</h3>
                        <p class="small opacity-75 mb-3">Domina la duela y encesta como las estrellas de la NBA.</p>
                        <div class="action-text">Reservar experiencia <i class="bi bi-arrow-right"></i></div>
                    </div>
                </a>
            </div>

            <div class="col-md-4">
                <a asp-controller="Canchas" asp-action="Index" class="sport-card-immersive">
                    <div class="card-bg" style="background-image: url('https://images.unsplash.com/photo-1612872087720-bb876e2e67d1?q=80&w=800&auto=format&fit=crop');"></div>
                    <div class="card-overlay"></div>
                    <div class="card-content">
                        <i class="bi bi-vimeo sport-icon" style="color: #0ea5e9;"></i>
                        <h3 class="fw-900 mb-1">Vóley</h3>
                        <p class="small opacity-75 mb-3">Pura técnica y salto. El remate perfecto está a un clic.</p>
                        <div class="action-text">Reservar experiencia <i class="bi bi-arrow-right"></i></div>
                    </div>
                </a>
            </div>

        </div>

        @* Footer del Dashboard *@
        <div class="row mt-5">
            <div class="col-12 text-center py-4 bg-white shadow-sm" style="border-radius: 20px; border-left: 5px solid #27F5CC;">
                <h5 class="fw-bold text-dark mb-0">
                    <i class="bi bi-rocket-takeoff-fill me-2 text-primary"></i>
                    Impulsando tu talento deportivo desde la <span style="color: #27F5CC;">ECUMEX</span>
                </h5>
            </div>
        </div>

    </div>
</div>